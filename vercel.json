{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "buildCommand": "cd front end && npm run build",
  "outputDirectory": "front end/dist",
  "installCommand": "cd front end && npm install",
  "framework": null,
  "rewrites": [
    {
      "source": "/stripe/callback",
      "destination": "https://saas-mbe-dev-staging-staging.up.railway.app/stripe/callback"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {"key": "X-Content-Type-Options", "value": "nosniff"},
        {"key": "X-Frame-Options", "value": "DENY"}
      ]
    }
  ]
}
